# Copy to .env.local for local development
# Set these as Cloud Run env vars for production (prefer Secret Manager for secrets)

# ─── Core ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173

# Mock mode — set to 'false' once real integrations are configured
USE_MOCK=true

# ─── Google Calendar OAuth ───────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALENDAR_REDIRECT_URI exactly
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ─── Salesforce Connected App ────────────────────────────────────
# Setup → Apps → App Manager → New Connected App
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_LOGIN_URL=https://login.salesforce.com
SF_CALLBACK_URL=http://localhost:8080/auth/salesforce/callback

# ─── Notifications ───────────────────────────────────────────────
SMS_EMAIL_NOTIFICATIONS_API_KEY=

# ─── External Partner Booking APIs ───────────────────────────────
GREENWATT_API_KEY=
VERSE_API_KEY=
SUNLINK_API_KEY=
LO_MANO_API_KEY=
REMIX_DYNAMICS_API_KEY=
